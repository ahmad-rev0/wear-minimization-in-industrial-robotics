{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://wear-minimization-in-industrial-robotics.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://wear-minimization-in-industrial-robotics.onrender.com/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
